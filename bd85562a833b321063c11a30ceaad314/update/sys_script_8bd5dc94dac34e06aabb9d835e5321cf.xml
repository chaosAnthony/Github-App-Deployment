        <script><![CDATA[
        // Log state changes for audit trail
        if (current.state.changes() || current.isNewRecord()) {
            var logMessage = current.isNewRecord() 
                ? 'New deployment request created with state: ' + current.getValue('state')
                : 'State changed from "' + previous.getValue('state') + '" to "' + current.getValue('state') + '"';
            
            gs.info('GitHub Deployment Request ' + current.getDisplayValue('number') + ': ' + logMessage);
            
            // Add info message for state changes that Flow Designer should process
            if (current.state.changesTo('ready_for_deployment')) {
                gs.addInfoMessage('Request submitted - Flow Designer will begin processing deployment');
            }
        }
    ]]></script>
