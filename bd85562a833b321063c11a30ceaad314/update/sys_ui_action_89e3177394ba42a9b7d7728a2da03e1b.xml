        <name>Submit for Deployment</name>
        <onclick/>
        <order>100</order>
        <script><![CDATA[
        // Validate required fields
        if (!current.github_repo_url) {
            g_form.addErrorMessage('GitHub Repository URL is required');
            return;
        }
        
        if (!current.application_scope) {
            g_form.addErrorMessage('Application Scope is required');
            return;
        }
        
        if (!current.target_instance_url) {
            g_form.addErrorMessage('Target Instance URL is required');
            return;
        }
        
        if (!current.target_instance_credentials) {
            g_form.addErrorMessage('Target Instance Credentials are required');
            return;
        }
        
        // Set state to trigger Flow Designer
        current.state = 'ready_for_deployment';
        current.update();
        
        g_form.addInfoMessage('Request submitted for deployment. Flow Designer will process this request.');
        g_form.reload();
    ]]></script>
